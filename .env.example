# ─── Public (safe to expose to the client bundle) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=https://carworkshop.ae

# Optional public analytics / contact (also configurable in Admin → Settings)
NEXT_PUBLIC_WHATSAPP_NUMBER=971XXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Server only (NEVER expose to the client) ───────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=admin@carworkshop.ae
RESEND_API_KEY=re_xxxxxxxxxxxx

# Rate limiting (Upstash Redis) — optional; lead form falls back to no-limit if unset
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# On-demand ISR revalidation webhook secret (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVALIDATION_SECRET=your_random_secret_minimum_32_characters

# Error monitoring
SENTRY_DSN=https://xxxx@sentry.io/xxxx
